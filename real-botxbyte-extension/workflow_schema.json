{
  "task_id": "botxbyte_workflow_001",
  "variables": {
    "email": "user@example.com",
    "password": "SecurePass123",
    "product_to_buy": "wireless headphones",
    "max_price": 500,
    "selected_size": "M",
    "selected_color": "Black"
  },
  "actions": [
    {
      "type": "navigate",
      "url": "https://example.com/login"
    },
    {
      "type": "wait_for",
      "selectors": ["#login-form", ".login-container"],
      "timeout": 8000
    },
    {
      "type": "if_exists",
      "selectors": [".cookie-banner", "#cookie-notice"],
      "then": {
        "type": "click",
        "selectors": ["button.accept-cookies", ".cookie-accept"]
      }
    },
    {
      "type": "fill",
      "selectors": ["input#email", "input[name='email']", "input[type='email']"],
      "value": "${email}",
      "human_typing": true,
      "delay": [70, 140]
    },
    {
      "type": "click",
      "selectors": ["button[type='submit']", "#login-btn"],
      "wait_after": 2000
    },
    {
      "type": "recaptcha_solve",
      "timeout": 300000
    },
    {
      "type": "extract",
      "selectors": ["h1.product-title", ".product-name"],
      "set_variable": "selected_product_name"
    },
    {
      "type": "select",
      "selectors": ["select#size"],
      "value": "${selected_size}"
    },
    {
      "type": "scroll",
      "direction": "down",
      "amount": 500
    },
    {
      "type": "hover",
      "selectors": [".product-item:first-child"]
    },
    {
      "type": "screenshot",
      "selectors": [".cart-container"]
    }
  ],
  "webhook": "https://your-tunnel.com/webhook",
  "webhook_payload": {
    "task_id": "${task_id}",
    "email": "${email}",
    "product_searched": "${product_to_buy}",
    "max_price": "${max_price}",
    "size": "${selected_size}",
    "color": "${selected_color}",
    "login_success": "${login_success}",
    "login_time": "${login_time}",
    "error_message": "${error_msg}",
    "products_found": "${products}",
    "selected_product": "${selected_product_name}",
    "captcha_solved": "${captcha_solved}"
  },
  "options": {
    "retry_on_failure": true,
    "max_retries": 3,
    "retry_delay": 5000
  }
}
