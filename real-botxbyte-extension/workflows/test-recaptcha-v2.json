{
  "url": "https://2captcha.com/demo/recaptcha-v2",
  "variables": {},
  "options": {
    "new_tab": true,
    "close_tab": true,
    "close_tab_on_error": true,
    "execution": {
      "stop_on_error": true
    }
  },
  "actions": [
    {
      "type": "focus_tab"
    },
    {
      "type": "wait_for",
      "selectors": ["body"],
      "timeout": 10000
    },
    {
      "type": "delay",
      "timeout": 3000
    },
    {
      "type": "recaptcha_solve",
      "max_attempts": 3
    }
  ]
}
