{
  "url": "https://chatgpt.com",
  "variables": {
    "query_id": ""
  },
  "options": {
    "new_tab": true,
    "close_tab": true,
    "close_tab_on_error": true
  },
  "actions": [
    {
      "type": "delay",
      "timeout": 3000
    },
    {
      "type": "evaluate",
      "script": "var loginBtn = document.querySelector('[data-testid=\"login-button\"]'); var signupBtn = document.querySelector('[data-testid=\"signup-button\"]'); if (loginBtn || signupBtn) { return 'not_logged_in'; } return 'logged_in';",
      "set_variable": "login_status"
    },
    {
      "type": "evaluate",
      "script": "return '${login_status}';",
      "set_variable": "success"
    }
  ],
  "webhook": "",
  "webhook_payload": {
    "query_id": "${query_id}",
    "login_status": "${login_status}",
    "error_message": "${error_message}",
    "service_type": "chatgpt-login-checker"
  }
}
