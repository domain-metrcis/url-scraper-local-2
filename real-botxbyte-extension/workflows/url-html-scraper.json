{
  "url": "about:blank",
  "variables": {
    "target_url": "https://botxbyte.com",
    "html_selector": "footer"
  },
  "options": {
    "new_tab": true,
    "close_tab": true,
    "close_tab_on_error": false
  },
  "actions": [
    {
      "type": "navigate",
      "url": "${target_url}"
    },
    {
      "type": "wait_for",
      "selectors": ["body"],
      "timeout": 30000
    },
    {
      "type": "delay",
      "timeout": 5000
    },
    {
      "type": "if_exists",
      "selectors": [
        ".cookie-banner",
        "[class*='cookie']",
        "[class*='consent']",
        "[class*='Cookie']",
        "[class*='Consent']",
        "[id*='cookie']",
        "[id*='consent']",
        "[class*='gdpr']",
        "[id*='gdpr']",
        "[id*='onetrust']",
        "[class*='cc-']",
        "[id*='CybotCookiebot']",
        "[class*='privacy-banner']",
        "[class*='cookie-notice']"
      ],
      "timeout": 3000,
      "actions": [
        {
          "type": "click",
          "selectors": [
            "button[class*='accept']",
            "button[class*='Accept']",
            "button[class*='agree']",
            "button[class*='Agree']",
            "button[id*='accept']",
            "button[id*='Accept']",
            "[class*='cookie'] button",
            "[class*='consent'] button",
            "[id*='onetrust-accept']",
            "#CybotCookiebotDialogBodyLevelButtonLevelOptinAllowAll",
            "text:Accept",
            "text:Accept All",
            "text:Accept all",
            "text:Accept cookies",
            "text:I agree",
            "text:Got it",
            "text:OK",
            "text:Allow all",
            "text:Allow All"
          ]
        }
      ]
    },
    {
      "type": "delay",
      "timeout": 2000
    },
    {
      "type": "evaluate",
      "script": "window.scrollTo(0, document.body.scrollHeight); return 'scrolled'"
    },
    {
      "type": "delay",
      "timeout": 2000
    },
    {
      "type": "evaluate",
      "script": "var selector = '${html_selector}'; var el = document.querySelector(selector); var html = el ? el.outerHTML : null; return JSON.stringify({ selector: selector, html: html })",
      "set_variable": "page_html"
    },
    {
      "type": "evaluate",
      "script": "return JSON.stringify({ title: document.title, url: window.location.href, domain: window.location.hostname })",
      "set_variable": "page_info"
    }
  ]
}
